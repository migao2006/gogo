# 請勿把真正的金鑰提交到 GitHub
TDX_CLIENT_ID=your_tdx_client_id
TDX_CLIENT_SECRET=your_tdx_client_secret

# Supabase 靜態公車資料庫（只在伺服器端使用）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 保護手動同步端點，請自行產生長隨機字串
STATIC_SYNC_SECRET=replace_with_a_long_random_secret

# 本機呼叫同步腳本時使用
APP_BASE_URL=http://localhost:3000

# 選填：地址搜尋服務識別字串
GEOCODER_USER_AGENT=TDX-Bus-Now/2.3.0

# 選填：TDX 呼叫節流與單次逾時
TDX_MIN_REQUEST_INTERVAL_MS=2200
TDX_REQUEST_TIMEOUT_MS=8000
TDX_RATE_LIMIT_COOLDOWN_MS=45000
